{
  "name": "talep-portal",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "bunx tailwindcss -i src/styles/app.css -o public/app.css --minify",
    "build:client": "bun build src/client/main.tsx --outfile public/client.js --target browser --format esm --minify --loader .css:text",
    "build:html": "cp src/client/index.html public/index.html",
    "build:editorcss": "cp node_modules/@uiw/react-md-editor/dist/mdeditor.min.css public/md-editor.css",
    "build": "bun run build:css && bun run build:client && bun run build:html && bun run build:editorcss",
    "dev:css": "bunx tailwindcss -i src/styles/app.css -o public/app.css --watch",
    "dev:client": "bun build src/client/main.tsx --outfile public/client.js --target browser --format esm --watch --loader .css:text",
    "dev:server": "bun --hot src/index.ts",
    "dev": "bun run build && (trap 'kill 0' EXIT; bun run dev:css & bun run dev:client & bun run dev:server)",
    "start": "bun run build && bun src/index.ts",
    "seed:definitions": "bun run scripts/seed-definitions.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@uiw/react-md-editor": "^4.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "nodemailer": "^6.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tiptap-markdown": "^0.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^3"
  }
}
