{
  "name": "talep-portal",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "bunx tailwindcss -i src/styles/app.css -o public/app.css --minify",
    "build": "bun run build:css",
    "dev:css": "bunx tailwindcss -i src/styles/app.css -o public/app.css --watch",
    "dev:server": "bun run --watch src/index.ts",
    "dev": "bun run build:css && (bun run dev:css & bun run dev:server)",
    "start": "bun run build && bun run src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.6.0",
    "lucide-react": "^1.18.0",
    "nodemailer": "^6.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "@types/nodemailer": "^6.4.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^3"
  }
}
